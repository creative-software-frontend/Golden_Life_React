<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E8A87C;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#C38D9E;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="100" cy="100" r="100" fill="#f3f4f6"/>
  
  <!-- Outer circle with gradient -->
  <circle cx="100" cy="100" r="90" fill="url(#grad1)" opacity="0.2"/>
  
  <!-- Inner circle -->
  <circle cx="100" cy="100" r="75" fill="white" opacity="0.5"/>
  
  <!-- Person icon - head -->
  <circle cx="100" cy="85" r="25" fill="url(#grad1)"/>
  
  <!-- Person icon - body -->
  <path d="M 100 115 Q 100 115 100 130 Q 100 155 70 170 L 130 170 Q 100 155 100 130 Q 100 115 100 115" fill="url(#grad1)"/>
  
  <!-- Shop/Business icon - small shop house on top right -->
  <g transform="translate(130, 40) scale(0.4)">
    <polygon points="0,20 25,5 50,20 50,50 0,50" fill="#E8A87C"/>
    <rect x="15" y="30" width="20" height="20" fill="#C38D9E"/>
  </g>
</svg>
